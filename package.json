  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch --no-shell",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "cross-env PRISMA_MODE=cli prisma generate cross-env PRISMA_MODE=server",
    "db:prune": "node ./scripts/db-prune.js",
    "db:migrate-dev": "cross-env PRISMA_MODE=cli POSTGRES_HOST=localhost prisma migrate dev cross-env PRISMA_MODE=server",
    "db:migrate-prod": "prisma migrate deploy",
    "db:migrate-clear": "node ./scripts/db-clear-migrations.js"
  },

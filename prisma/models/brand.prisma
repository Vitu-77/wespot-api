model Brand {
  id          String          @id @default(uuid())
  name        String
  segment     BusinessSegment
  description String?
  logoKey     String?         @map("logo_key")
  slogan      String?
  phoneNumber String?         @map("phone_number")
  whatsapp    String?
  instagram   String?
  tiktok      String?
  facebook    String?
  website     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  spots     Spot[]
  addresses BrandAddress[]

  @@index([workspaceId])
  @@map("brands")
}

model BrandAddress {
  id           String          @id @default(uuid())
  state        BrazilianState?
  city         String?
  neighborhood String?
  street       String?
  number       String?
  complement   String?

  brandId String @map("brand_id")
  brand   Brand  @relation(fields: [brandId], references: [id])

  responsibles BrandResponsible[]

  @@index([brandId])
  @@map("brand_addresses")
}

model BrandResponsible {
  id   String  @id @default(uuid())
  role String?
  name String

  brandAddressId String       @map("brand_address_id")
  brandAddress   BrandAddress @relation(fields: [brandAddressId], references: [id])

  @@index([brandAddressId])
  @@map("brand_addresses_responsibles")
}

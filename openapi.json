          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "script": {
            "type": "string"
          },
          "audioUrl": {
            "type": "object"
          },
          "starred": {
            "type": "boolean"
          },
          "expectedDuration": {
            "type": "number"
          },
          "audioDuration": {
            "type": "object"
          },
          "workspaceId": {
            "type": "string"
          },
          "workspace": {
            "type": "object"
          },
          "brandId": {
            "type": "object"
          },
          "brand": {
            "type": "object"
          },
          "inputId": {
            "type": "object"
          },
          "voiceId": {

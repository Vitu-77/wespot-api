{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/accounts/signin/email": {
      "post": {
        "description": "Authenticates a user using an email address and password.",
        "operationId": "signInWithEmail",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SigninWithEmailDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully authenticated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SigninWithEmailResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Password does not match.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Password does not match.",
                  "error": "PASSWORDS_DO_NOT_MATCH",
                  "statusCode": 401
                }
              }
            }
          },
          "404": {
            "description": "User not found with this email.",
            "content": {
              "application/json": {
                "example": {
                  "message": "User not found with this email.",
                  "error": "EMAIL_NOT_FOUND",
                  "statusCode": 404
                }
              }
            }
          }
        },
        "summary": "Sign in with email",
        "tags": [
          "Accounts"
        ]
      }
    },
    "/api/v1/accounts/signin/google": {
      "post": {
        "description": "Authenticates a user using a Google ID Token.",
        "operationId": "signInWithGoogle",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SigninWithGoogleDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully authenticated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SigninWithGoogleResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Google token is invalid.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Google token is invalid.",
                  "error": "INVALID_GOOGLE_TOKEN",
                  "statusCode": 400
                }
              }
            }
          },
          "401": {
            "description": "Google account is incomplete.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Google account is incomplete.",
                  "error": "GOOGLE_ACCOUNT_INCOMPLETE",
                  "statusCode": 401
                }
              }
            }
          },
          "404": {
            "description": "The requested resource was not found.",
            "content": {
              "application/json": {
                "examples": {
                  "EMAIL_NOT_FOUND": {
                    "summary": "Email not found",
                    "value": {
                      "description": "User not found with this email.",
                      "example": {
                        "message": "User not found with this email.",
                        "error": "EMAIL_NOT_FOUND",
                        "statusCode": 404
                      }
                    }
                  },
                  "GOOGLE_ACCOUNT_NOT_FOUND": {
                    "summary": "Google account not found",
                    "value": {
                      "description": "Google account was not found.",
                      "example": {
                        "message": "Google account was not found.",
                        "error": "GOOGLE_ACCOUNT_NOT_FOUND",
                        "statusCode": 404
                      }
                    }
                  },
                  "USER_HAS_LOGIN_WITH_EMAIL": {
                    "summary": "Account uses email authentication",
                    "value": {
                      "description": "This account uses email and password authentication.",
                      "example": {
                        "message": "This account uses email and password authentication.",
                        "error": "USER_HAS_LOGIN_WITH_EMAIL",
                        "statusCode": 404
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Sign in with Google",
        "tags": [
          "Accounts"
        ]
      }
    },
    "/api/v1/accounts/signin": {
      "delete": {
        "description": "Invalidates the current authenticated session.",
        "operationId": "signout",
        "parameters": [],
        "responses": {
          "204": {
            "description": "User successfully signed out."
          },
          "401": {
            "description": "Authentication token is missing.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Authentication token is missing.",
                  "error": "AUTH_TOKEN_IS_MISSING",
                  "statusCode": 401
                }
              }
            }
          }
        },
        "summary": "Sign out",
        "tags": [
          "Accounts"
        ]
      }
    },
    "/api/v1/accounts/signup/email": {
      "post": {
        "description": "Creates a new account using an email address and password, sends a verification code to the user's email, and creates an authenticated session.",
        "operationId": "signUpWithEmail",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountWithEmailDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account successfully created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAccountWithEmailResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Password does not match.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Password does not match.",
                  "error": "PASSWORDS_DO_NOT_MATCH",
                  "statusCode": 401
                }
              }
            }
          },
          "409": {
            "description": "The account could not be created.",
            "content": {
              "application/json": {
                "examples": {
                  "EMAIL_ALREADY_IN_USE": {
                    "summary": "Email already in use",
                    "value": {
                      "description": "Email is already in use.",
                      "example": {
                        "message": "Email is already in use.",
                        "error": "EMAIL_ALREADY_IN_USE",
                        "statusCode": 409
                      }
                    }
                  },
                  "EMAIL_ALREADY_REGISTERED_WITH_GOOGLE": {
                    "summary": "Email already registered with Google",
                    "value": {
                      "description": "This email is already registered with Google authentication.",
                      "example": {
                        "message": "This email is already registered with Google authentication.",
                        "error": "EMAIL_ALREADY_REGISTERED_WITH_GOOGLE",
                        "statusCode": 409
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Create account with email",
        "tags": [
          "Accounts"
        ]
      }
    },
    "/api/v1/accounts/signup/google": {
      "post": {
        "description": "Creates a new account using a Google account. If the user already exists with Google authentication, a new session is created instead.",
        "operationId": "signUpWithGoogle",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountWithGoogleDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account successfully created or authenticated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAccountWithGoogleResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Google token is invalid.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Google token is invalid.",
                  "error": "INVALID_GOOGLE_TOKEN",
                  "statusCode": 400
                }
              }
            }
          },
          "401": {
            "description": "Google account is incomplete.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Google account is incomplete.",
                  "error": "GOOGLE_ACCOUNT_INCOMPLETE",
                  "statusCode": 401
                }
              }
            }
          },
          "404": {
            "description": "Google account was not found.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Google account was not found.",
                  "error": "GOOGLE_ACCOUNT_NOT_FOUND",
                  "statusCode": 404
                }
              }
            }
          },
          "409": {
            "description": "This email is already registered with password authentication.",
            "content": {
              "application/json": {
                "example": {
                  "message": "This email is already registered with password authentication.",
                  "error": "EMAIL_ALREADY_REGISTERED_WITH_PASSWORD",
                  "statusCode": 409
                }
              }
            }
          }
        },
        "summary": "Create account with Google",
        "tags": [
          "Accounts"
        ]
      }
    },
    "/api/v1/accounts/signup/validate-email": {
      "patch": {
        "description": "Validates the verification code sent to the user's email address and marks the email as verified.",
        "operationId": "validateEmailWithCode",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateVerificationCodeDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email successfully verified.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateVerificationCodeResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "The verification code is invalid.",
            "content": {
              "application/json": {
                "examples": {
                  "VERIFICATION_CODE_EXPIRED": {
                    "summary": "Verification code expired",
                    "value": {
                      "description": "Verification code has expired.",
                      "example": {
                        "message": "Verification code has expired.",
                        "error": "VERIFICATION_CODE_EXPIRED",
                        "statusCode": 400
                      }
                    }
                  },
                  "VERIFICATION_CODE_INCORRECT": {
                    "summary": "Verification code incorrect",
                    "value": {
                      "description": "Verification code is incorrect.",
                      "example": {
                        "message": "Verification code is incorrect.",
                        "error": "VERIFICATION_CODE_INCORRECT",
                        "statusCode": 400
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "User not found with this email.",
            "content": {
              "application/json": {
                "example": {
                  "message": "User not found with this email.",
                  "error": "EMAIL_NOT_FOUND",
                  "statusCode": 404
                }
              }
            }
          }
        },
        "summary": "Validate email verification code",
        "tags": [
          "Accounts"
        ]
      }
    },

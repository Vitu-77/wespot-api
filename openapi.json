      "CreateAccountWithGoogleResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "refreshTokenHash": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "userId",
          "refreshTokenHash",
          "createdAt"
        ]
      },

  "info": {
    "title": "WeSpot API",
    "description": "Endpoints for WeSpot API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "schemas": {
      "SigninWithEmailDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SigninSessionResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "refreshTokenHash": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date"
          }
        },
        "required": [
          "userId",
          "refreshTokenHash",
          "createdAt"
        ]
      },
      "SigninWithEmailResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "session": {
            "$ref": "#/components/schemas/SigninSessionResponseDto"
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "session"
        ]
      },
      "SigninWithGoogleDto": {
        "type": "object",
        "properties": {
          "googleIdToken": {
            "type": "string"
          }
        },
        "required": [
          "googleIdToken"
        ]
      },
      "SigninWithGoogleResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },

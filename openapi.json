  "info": {
    "title": "WeSpot API",
    "description": "Endpoints for WeSpot API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "schemas": {
      "SigninWithEmailDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 1
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SigninSessionResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "refreshTokenHash": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date"
          }
        },
        "required": [
          "userId",
          "refreshTokenHash",
          "createdAt"
        ]
      },
      "SigninWithEmailResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT utilizado para autenticação."
          },
          "refreshToken": {
            "type": "string",
            "description": "Token utilizado para renovar a sessão."
          },
          "session": {
            "description": "Sessão autenticada do usuário.",
            "allOf": [
              {
                "$ref": "#/components/schemas/SigninSessionResponseDto"
              }
            ]
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "session"
        ]
      },
      "SigninWithGoogleDto": {
        "type": "object",
        "properties": {
          "googleIdToken": {
            "type": "string",
            "description": "Token OAuth do Google."
          }
        },
        "required": [
          "googleIdToken"
        ]
      },
      "SigninWithGoogleResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT utilizado para autenticação."
          },
          "refreshToken": {
            "type": "string",
            "description": "Token utilizado para renovar a sessão."
          },
          "session": {
            "description": "Sessão autenticada do usuário.",
            "allOf": [
              {
                "$ref": "#/components/schemas/SigninSessionResponseDto"
              }
            ]
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "session"
        ]
      },
      "CreateAccountWithEmailDto": {
        "type": "object",
        "properties": {}
